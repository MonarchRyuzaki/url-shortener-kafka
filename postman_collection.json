{
	"info": {
		"_postman_id": "78a9c8d2-4b3e-4f5a-9d2c-8b1e4f5a6d7c",
		"name": "Url Shortener Kafka API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Shorten URL (Success)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has shortUrlKey\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.shortUrlKey).to.be.a('string');",
							"    pm.expect(jsonData.shortUrlKey.length).to.equal(7);",
							"    pm.collectionVariables.set(\"shortUrlKey\", jsonData.shortUrlKey);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"url\": \"https://www.google.com\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/shorten",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"shorten"
					]
				}
			},
			"response": []
		},
		{
			"name": "Shorten URL (Invalid URL)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 400\", function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test(\"Error message is correct\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.include(\"Invalid URL\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"url\": \"not-a-valid-url\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/shorten",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"shorten"
					]
				}
			},
			"response": []
		},
		{
			"name": "Resolve URL (Redirect)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 308 (Permanent Redirect)\", function () {",
							"    pm.response.to.have.status(308);",
							"});",
							"",
							"pm.test(\"Location header is present\", function () {",
							"    pm.response.to.have.header(\"Location\");",
							"    pm.expect(pm.response.headers.get(\"Location\")).to.equal(\"https://www.google.com\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/{{shortUrlKey}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"{{shortUrlKey}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Resolve URL (Not Found)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 404\", function () {",
							"    pm.response.to.have.status(404);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/nonExistentKey",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"nonExistentKey"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "shortUrlKey",
			"value": ""
		}
	]
}
